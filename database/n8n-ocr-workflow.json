    },
    "GPT-4o Vision OCR": {
      "main": [[{ "node": "Parse & Validate Output", "type": "main", "index": 0 }]]
    },
    "Parse & Validate Output": {
      "main": [[{ "node": "Save OCR Result to Supabase", "type": "main", "index": 0 }]]
    },
    "Save OCR Result to Supabase": {
      "main": [[
        { "node": "Update Status: Completed", "type": "main", "index": 0 },
        { "node": "Update Document Status", "type": "main", "index": 0 }
      ]]
    },
    "Update Status: Completed": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
